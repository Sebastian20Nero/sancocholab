# =============================
# SancochoLab - Global settings
# =============================

# --- Docker / PostgreSQL ---
POSTGRES_USER=sancocholab
POSTGRES_PASSWORD=sancocholab
POSTGRES_DB=sancocholab
DB_PORT=5432

# --- API / NestJS ---
API_PORT=3000
NODE_ENV=production
JWT_SECRET=change_me_with_a_long_random_secret
BOOTSTRAP_SECRET=change_me_bootstrap_secret

# Optional: seed admin user on startup when PRISMA_RUN_SEED=true
ADMIN_EMAIL=johanstian20@hotmail.com
ADMIN_PASSWORD=rmmr
ADMIN_NOMBRES=Johan
ADMIN_APELLIDOS=Stian
ADMIN_CELULAR=3178333333

# En local del equipo dejamos true para crear automaticamente usuario admin.
# En produccion se recomienda false y crear usuarios por proceso controlado.
PRISMA_RUN_SEED=true

# --- Optional tooling (pgAdmin) ---
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@sancocholab.com
PGADMIN_DEFAULT_PASSWORD=admin123
