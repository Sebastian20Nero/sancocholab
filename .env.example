# =============================
# SancochoLab - Global settings
# =============================

# --- Docker / PostgreSQL ---
POSTGRES_USER=sancocholab
POSTGRES_PASSWORD=sancocholab
POSTGRES_DB=sancocholab
DB_PORT=5432

# --- API / NestJS ---
API_PORT=3000
NODE_ENV=development
JWT_SECRET=change_me_with_a_long_secret
BOOTSTRAP_SECRET=change_me_bootstrap_secret
# En local puedes dejar estos valores por defecto.
# En servidor cambia CORS_ORIGINS por tu dominio o IP publica.
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000
SWAGGER_ENABLED=true

# Opcional: admin por seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123
ADMIN_NOMBRES=Admin
ADMIN_APELLIDOS=SancochoLab
ADMIN_CELULAR=3000000000

# true para primer arranque / false para uso normal diario
PRISMA_RUN_SEED=false

# --- pgAdmin (opcional) ---
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@sancocholab.com
PGADMIN_DEFAULT_PASSWORD=admin123

# --- Frontend / servidor Ubuntu ---
WEB_PORT=80
